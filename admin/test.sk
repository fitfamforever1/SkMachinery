command /dummy:
    permission: admin.test
    trigger:
        set {_loc} to player's location
        spawn armor stand at {_loc}
        set {_e} to last spawned entity
        set max health of {_e} to 1000
        set health of {_e} to 1000
       
command /giveweapon <text>:
    permission: op
    trigger:
        if arg-1 is "rustedshortsword":
            give sword(wooden sword named "&fRusted Shortsword", 1) to player
        else if arg-1 is "huntersknife":
            give dagger(golden sword named "&fHunter's Knife", 1) to player

        else if arg-1 is "lumberhatchet":
            give axe(stone axe named "&fLumber Hatchet", 2) to player
        else if arg-1 is "bronzesword":
            give sword(stone sword named "&fBronze Sword", 2) to player

        else if arg-1 is "scoutdirk":
            give dagger(golden sword named "&fScout Dirk", 3) to player
        else if arg-1 is "splitteraxe":
            give axe(stone axe named "&fSplitter Axe", 3) to player

        else if arg-1 is "guardsword":
            give sword(iron sword named "&fGuard Sword", 4) to player
        else if arg-1 is "banditshiv":
            give dagger(golden sword named "&fBandit Shiv", 4) to player

        else if arg-1 is "raideraxe":
            give axe(iron axe named "&fRaider Axe", 5) to player
        else if arg-1 is "ironbroadsword":

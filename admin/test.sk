            give axe(diamond axe named "&fLeviathan Axe", 27) to player

        else if arg-1 = 28:
            give sword(diamond sword named "&fTempest Blade", 28) to player
            give dagger(golden sword named "&fVoid Dirk", 28) to player

        else if arg-1 = 29:
            give axe(diamond axe named "&fWorld Splitter", 29) to player
            give sword(diamond sword named "&fEmperor's Sword", 29) to player

        else if arg-1 = 30:

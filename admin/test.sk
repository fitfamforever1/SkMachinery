command /dummy:
    permission: admin.test
    trigger:
        set {_loc} to player's location
        spawn armor stand at {_loc}
        set {_e} to last spawned entity
        set max health of {_e} to 1000
        set health of {_e} to 1000
       
command /giveweapon <number>:
    permission: op
    trigger:
        if arg-1 = 1:
            give sword(wooden sword named "&fRusted Shortsword", 1) to player
            give dagger(golden sword named "&fHunter's Knife", 1) to player

        else if arg-1 = 2:
            give axe(stone axe named "&fLumber Hatchet", 2) to player
            give sword(stone sword named "&fBronze Sword", 2) to player

        else if arg-1 = 3:
            give dagger(golden sword named "&fScout Dirk", 3) to player
            give axe(stone axe named "&fSplitter Axe", 3) to player

        else if arg-1 = 4:
            give sword(iron sword named "&fGuard Sword", 4) to player
            give dagger(golden sword named "&fBandit Shiv", 4) to player

        else if arg-1 = 5:
            give axe(iron axe named "&fRaider Axe", 5) to player
            give sword(iron sword named "&fIron Broadsword", 5) to player

        else if arg-1 = 6:
            give dagger(golden sword named "&fTwin Fangs", 6) to player
            give axe(iron axe named "&fHeavy Cleaver", 6) to player

        else if arg-1 = 7:
            give sword(iron sword named "&fMercenary Blade", 7) to player
            give axe(iron axe named "&fWoodman's Axe", 7) to player

        else if arg-1 = 8:
            give dagger(golden sword named "&fVenom Fang", 8) to player
            give sword(iron sword named "&fSoldier Sword", 8) to player

        else if arg-1 = 9:
            give axe(iron axe named "&fSkull Splitter", 9) to player
            give sword(iron sword named "&fKnight's Blade", 9) to player

        else if arg-1 = 10:
            give dagger(golden sword named "&fSilent Dagger", 10) to player
            give axe(diamond axe named "&fWar Axe", 10) to player

        else if arg-1 = 11:
            give sword(diamond sword named "&fCrimson Saber", 11) to player
            give axe(diamond axe named "&fButcher Cleaver", 11) to player

        else if arg-1 = 12:
            give dagger(golden sword named "&fShadow Fang", 12) to player
            give sword(diamond sword named "&fWarden Blade", 12) to player

        else if arg-1 = 13:
            give axe(diamond axe named "&fRavager Axe", 13) to player
            give sword(diamond sword named "&fMoonsteel Sword", 13) to player

        else if arg-1 = 14:
            give dagger(golden sword named "&fAssassin Dirk", 14) to player
            give sword(diamond sword named "&fPaladin Blade", 14) to player

        else if arg-1 = 15:
            give sword(diamond sword named "&fFrostfang", 15) to player
            give axe(diamond axe named "&fCrusher Axe", 15) to player

        else if arg-1 = 16:
            give dagger(golden sword named "&fPhantom Knife", 16) to player
            give sword(diamond sword named "&fChampion Sword", 16) to player

        else if arg-1 = 17:
            give dagger(golden sword named "&fBloodletter", 17) to player
            give axe(diamond axe named "&fMountain Breaker", 17) to player

        else if arg-1 = 18:
            give sword(diamond sword named "&fDragonbone Sword", 18) to player
            give axe(diamond axe named "&fDread Cleaver", 18) to player

        else if arg-1 = 19:
            give dagger(golden sword named "&fSerpent Tooth", 19) to player
            give sword(diamond sword named "&fRoyal Longsword", 19) to player

        else if arg-1 = 20:
            give axe(diamond axe named "&fColossus Axe", 20) to player
            give sword(diamond sword named "&fSunfire Blade", 20) to player

        else if arg-1 = 21:
            give dagger(golden sword named "&fBlack Lotus", 21) to player
            give axe(diamond axe named "&fInfernal Axe", 21) to player

        else if arg-1 = 22:
            give sword(diamond sword named "&fHollow Edge", 22) to player
            give dagger(golden sword named "&fGhost Fang", 22) to player

        else if arg-1 = 23:
            give axe(diamond axe named "&fTitan Cleaver", 23) to player

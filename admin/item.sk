function boots(item: item, level: number):: item:
    set {_type} to "boots"
    set {_health} to round((25 + ({_level} * 2.5)) * 1.15)
    set {_speed} to round(2 + ({_level} * 0.15))
    set {_critchance} to round(1 + ({_level} * 0.06))
    
    set {_typeline} to SmallCaps({_type})
    set line 1 of lore of {_item} to "&8┃ &7» ɪᴛᴇᴍ ɪɴғᴏ"
    set line 2 of lore of {_item} to "&8┃ &7ᴛʏᴘᴇ &8» &e%{_typeLine}%"
    set line 3 of lore of {_item} to "&8┃ &7ʟᴇᴠᴇʟ &8» &c%{_level}%"
    set line 4 of lore of {_item} to ""
    set line 5 of lore of {_item} to "&8┃ &7» ɪᴛᴇᴍ ꜱᴛᴀᴛꜱ"
    set line 6 of lore of {_item} to "&8┃ &7ʜᴇᴀʟᴛʜ &8» &c+%{_health}%"
    set line 7 of lore of {_item} to "&8┃ &7ꜱᴘᴇᴇᴅ &8» &f+%{_speed}%"
    set line 8 of lore of {_item} to "&8┃ &7ᴄʀɪᴛ ᴄʜᴀɴᴄᴇ &8» &9+%{_critchance}%%%"
    
    set {_item} to unbreakable {_item}
    set item flags of {_item} to all item flags
    set number data tag "itemstat:level" of {_item} to {_level}
    set data tag "itemstat:type" of {_item} to {_type}
    set number data tag "itemstat:health" of {_item} to {_health}
    set number data tag "itemstat:speed" of {_item} to {_speed}
    set number data tag "itemstat:crit_chance" of {_item} to {_critchance}
    
    return {_item}
    
command /modifyarmor <number>:
    permission: admin.item
    trigger:
        set {_item} to player's tool
        if {_item} is air:
            send "&cYou must be holding a piece of armor."
            stop
        
        if {_item} is tagged as item tag "helmets":
            set {_item} to helmet({_item}, arg-1)
            set {_slot} to "helmet"
        else if {_item} is tagged as item tag "chestplates":
            set {_item} to chestplate({_item}, arg-1)
            set {_slot} to "chestplate"
        else if {_item} is tagged as item tag "leggings":
            set {_item} to leggings({_item}, arg-1)
            set {_slot} to "leggings"
        else if {_item} is tagged as item tag "boots":
            set {_item} to boots({_item}, arg-1)
            set {_slot} to "boots"
        else:
            send "&cYou must be holding a piece of armor (helmet/chestplate/leggings/boots)."
            stop
        
        set player's tool to {_item}
        send "&aModified armor to &eLvl %arg-1% %{_slot}%&a."
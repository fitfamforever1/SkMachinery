command /givehelmet <number>:
    permission: admin.item
    trigger:
        giveHelmet(player, arg-1)

command /givechestplate <number>:
    permission: admin.item
    trigger:
        giveChestplate(player, arg-1)

command /giveleggings <number>:
    permission: admin.item
    trigger:
        giveLeggings(player, arg-1)

command /giveboots <number>:
    permission: admin.item
    trigger:
        giveBoots(player, arg-1)

command /giveset <number>:
    permission: admin.item
    trigger:
        giveHelmet(player, arg-1)
        giveChestplate(player, arg-1)
        giveLeggings(player, arg-1)
        giveBoots(player, arg-1)
        case 26:
            give helmet("Driftwood Hood", 26, " ") to {_p}
        case 27:
            give helmet("Icebound Casque", 27, " ") to {_p}
        case 28:
            give helmet("Ashfall Cap", 28, " ") to {_p}
        case 29:
            give helmet("Boneyard Helm", 29, " ") to {_p}
        case 30:
            give helmet("Warforged Cap", 30, " ") to {_p}
        default:
            send "&cInvalid armor ID." to {_p}

function giveChestplate(p: player, id: number):
    switch {_id}:
        case 1:
            give chestplate(leather chestplate, "Rotten Vest", 1, 121, 127, 68) to {_p}
        case 2:
            give chestplate(leather chestplate, "Frosted Cuirass", 2, 113, 178, 201) to {_p}

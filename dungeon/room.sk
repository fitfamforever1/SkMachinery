function teleportToRoom(p: player, room: number):
    set {_baseX} to 88.5
    set {_baseY} to 1
    set {_baseZ} to 99.5
    set {_spacing} to 32

    set {_targetZ} to {_baseZ} + (({_room} - 1) * {_spacing})

    set {_loc} to location({_baseX}, {_baseY}, {_targetZ}, world of {_p})
    teleport {_p} to {_loc}
    
command /room <number>:
    trigger:
        teleportToRoom(player, arg-1)